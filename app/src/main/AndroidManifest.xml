<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Package-visibility entry for Android 11+ so we can detect and
         bind to the BRouter app for bike-aware offline routing. We
         bind by explicit component (BRouter's service has no
         intent-filter) so a <package> entry is enough. -->
    <queries>
        <package android:name="btools.routingapp" />
    </queries>

    <!-- Trip tracking foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Runtime-requested on API 33+; declared here for older targetSDK compat -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GPXIT">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.GPXIT">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Receive shared GPX files. Komoot / Strava / Garmin
                 share with the official application/gpx+xml MIME;
                 generic share sheets often hand us octet-stream or
                 a text/xml fallback when the source app doesn't tag
                 the type. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/gpx+xml" />
                <data android:mimeType="application/x-gpx+xml" />
                <data android:mimeType="application/gpx" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="text/xml" />
                <data android:mimeType="application/xml" />
            </intent-filter>

            <!-- Receive a shared Komoot URL as plain text. Komoot's own
                 "Share tour" action emits text/plain with the public
                 link in EXTRA_TEXT; MainActivity parses the URL and
                 dispatches to the Komoot import path. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!-- Open a Komoot tour deep link. Tapping a komoot.com /
                 komoot.de link in browser, chat, or email goes through
                 the Android chooser and lands here so MainActivity can
                 fetch the tour via the Komoot API. autoVerify=false
                 because we don't control the assetlinks.json on
                 komoot.com — the chooser dialog is the right UX. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="komoot.com" />
                <data android:host="www.komoot.com" />
                <data android:host="komoot.de" />
                <data android:host="www.komoot.de" />
            </intent-filter>

            <!-- Open GPX files by MIME — broad list deliberately
                 mirrors Komoot's manifest (de.komoot.android,
                 TrackImportActivity). On Android the MIME for .gpx
                 isn't shipped in the system tables, so file managers
                 commonly hand the file out as application/octet-
                 stream or text/xml; without these wildcard-ish MIMEs
                 we never appear in the chooser. The trade-off is
                 that GPXIT will be offered as one of the apps for
                 arbitrary binary / XML files — same trade-off Komoot
                 makes. The pin is the .gpx pathPattern (next filter)
                 which keeps us from being the *default*. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="application/gpx+xml" />
                <data android:mimeType="application/x-gpx+xml" />
                <data android:mimeType="application/gpx" />
                <data android:mimeType="application/xml" />
                <data android:mimeType="text/xml" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>

            <!-- Open GPX files by extension — covers browsers, mail
                 attachments, and file managers that hand us
                 application/octet-stream or a wildcard type but get
                 the path right. Multiple pathPatterns because
                 Android's `.*` matching chokes on paths with extra
                 dots (e.g. "tour.2026-04.gpx"). Both lower- and
                 upper-case extensions because some exporters write
                 .GPX. http/https schemes catch direct downloads from
                 a browser address bar. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:scheme="http" />
                <data android:scheme="https" />
                <data android:host="*" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.gpx" />
                <data android:pathPattern=".*\\..*\\.gpx" />
                <data android:pathPattern=".*\\..*\\..*\\.gpx" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.gpx" />
                <data android:pathPattern=".*\\.GPX" />
                <data android:pathPattern=".*\\..*\\.GPX" />
                <data android:pathPattern=".*\\..*\\..*\\.GPX" />
                <data android:pathPattern=".*\\..*\\..*\\..*\\.GPX" />
            </intent-filter>
        </activity>

        <service
            android:name=".data.tracking.TripTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />
    </application>
</manifest>
